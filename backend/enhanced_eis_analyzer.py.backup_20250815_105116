    def _generate_cache_key(self, frequencies: List[float],
                          real_parts: List[float],
                          imag_parts: List[float]) -> str:
        """生成缓存键"""
        try:
            import hashlib
            # 使用数据的哈希值作为缓存键
            data_str = f"{frequencies}{real_parts}{imag_parts}"
            return hashlib.md5(data_str.encode()).hexdigest()[:16]
        except:
            import time
            return f"fallback_{time.time()}"

    def clear_cache(self):
        """清空计算缓存"""
        self.calculation_cache.clear()
        self.logger.info("🧹 EIS计算缓存已清空")

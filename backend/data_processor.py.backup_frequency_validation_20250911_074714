    def enhanced_eis_analysis(self, impedance_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        增强版EIS分析方法

        Args:
            impedance_data: 阻抗数据字典，包含frequencies, real_parts, imag_parts

        Returns:
            增强版EIS分析结果
        """
        try:
            logger.debug("开始增强版EIS分析...")

            # 提取数据
            frequencies = impedance_data.get('frequencies', [])
            real_parts = impedance_data.get('real_parts', [])
            imag_parts = impedance_data.get('imag_parts', [])

            if not frequencies or not real_parts or not imag_parts:
                logger.warning("阻抗数据不完整，无法进行增强版EIS分析")
                return {'analysis_success': False, 'error': '数据不完整'}

            if len(frequencies) != len(real_parts) or len(frequencies) != len(imag_parts):
                logger.warning("阻抗数据长度不匹配")
                return {'analysis_success': False, 'error': '数据长度不匹配'}

            # 使用标准EIS分析器
            cell_id = f"CH_{impedance_data.get('channel', 'Unknown')}"
            result = self.eis_analyzer.calculate_rs_rct_enhanced(
                frequencies, real_parts, imag_parts, cell_id
            )

            if result and result.get('analysis_success'):
                logger.debug(f"标准EIS分析成功: Rs={result.get('rs_value', 0):.3f}mΩ, "
                           f"Rct={result.get('rct_value', 0):.3f}mΩ, "
                           f"Rsei={result.get('rsei_value', 0):.3f}mΩ")
                return result
            else:
                logger.warning("标准EIS分析失败，回退到简化分析")

            # 回退到简化分析
            return self._simplified_eis_analysis(frequencies, real_parts, imag_parts)

        except Exception as e:
            logger.error(f"增强版EIS分析异常: {e}")
            return {'analysis_success': False, 'error': str(e)}

    def _simplified_eis_analysis(self, frequencies: List[float], real_parts: List[float],
                                imag_parts: List[float]) -> Dict[str, Any]:
        """
        简化版EIS分析（回退方案）

        Args:
            frequencies: 频率列表
            real_parts: 实部列表
            imag_parts: 虚部列表

        Returns:
            简化分析结果
        """
        try:
            # 基本参数计算
            rs_value = real_parts[0] if real_parts else 0.0  # 高频实部作为Rs
            total_resistance = real_parts[-1] if real_parts else 0.0  # 低频实部作为总阻抗

            # 简化的Rsei计算（严格检测SEI特征）
            rsei_value = 0.0
            if len(frequencies) > 5:  # 需要足够的数据点
                # 寻找高频区域的阻抗变化
                high_freq_indices = [i for i, f in enumerate(frequencies) if f > 100]
                if len(high_freq_indices) >= 4:  # 需要足够的高频点
                    high_freq_real = [real_parts[i] for i in high_freq_indices]
                    real_change = max(high_freq_real) - min(high_freq_real)
                    total_change = total_resistance - rs_value

                    # 更严格的SEI检测条件：
                    # 1. 高频变化超过总变化的15%
                    # 2. 绝对变化大于1.0mΩ
                    # 3. 总阻抗变化足够大（避免噪声）
                    if (real_change > 0.15 * total_change and
                        real_change > 1.0 and
                        total_change > 5.0):
                        rsei_value = real_change
                        logger.debug(f"检测到SEI特征: 变化={real_change:.3f}mΩ, 占比={real_change/total_change*100:.1f}%")
                    else:
                        logger.debug(f"未检测到明显SEI特征: 变化={real_change:.3f}mΩ, 占比={real_change/total_change*100:.1f}%")

            # 计算Rct
            rct_value = max(0.0, total_resistance - rs_value - rsei_value)

            result = {
                'analysis_success': True,
                'rs_value': rs_value,
                'rct_value': rct_value,
                'rsei_value': rsei_value,
                'warburg_coefficient': 0.0,
                'health_status': 'unknown',
                'analysis_method': 'simplified'
            }

            logger.debug(f"简化EIS分析完成: Rs={rs_value:.3f}mΩ, Rct={rct_value:.3f}mΩ, Rsei={rsei_value:.3f}mΩ")
            return result

        except Exception as e:
            logger.error(f"简化EIS分析失败: {e}")
            return {
                'analysis_success': False,
                'error': str(e),
                'rs_value': 0.0,
                'rct_value': 0.0,
                'rsei_value': 0.0
            }
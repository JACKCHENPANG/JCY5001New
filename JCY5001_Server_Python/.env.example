# 数据库配置
DATABASE_URL=sqlite:///battery_test.db

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=7200

# Flask配置
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_RUN_PORT=5002

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log

# 机器学习模型配置
MODEL_DIR=models
TRAINING_DATA_SIZE=2000


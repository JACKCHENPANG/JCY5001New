    def is_impedance_optimized_preset(self) -> tuple:
        """
        检查当前是否使用阻抗优化的预设配置

        Returns:
            (is_optimized, impedance_type):
            - is_optimized: 是否为阻抗优化配置
            - impedance_type: 阻抗类型 ('ultra_low', 'high', 'standard')
        """
        preset_name = self.get_current_preset_name()

        if preset_name == "<1mΩ内阻频点":
            return True, 'ultra_low'
        elif preset_name == ">10mΩ内阻频点":
            return True, 'high'
        else:
            return False, 'standard'


            else:
                # 需要调整
                self.frequency_match_label.setText(f"📍 将匹配到设备预设频点: {matched_freq:.3f}Hz (调整: {freq_diff:+.3f}Hz)")
                self.frequency_match_label.setStyleSheet("color: #FF8C00; font-size: 11px; padding: 2px;")


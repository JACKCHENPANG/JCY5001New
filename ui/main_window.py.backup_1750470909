            logger.info("🎯 _on_all_channels_ready方法被调用")

            # 🔧 修复：添加重复调用检查，避免多次处理
            if hasattr(self, '_all_channels_ready_processed') and self._all_channels_ready_processed:
                logger.debug("所有通道就绪已处理过，跳过重复处理")
                return

            self._all_channels_ready_processed = True

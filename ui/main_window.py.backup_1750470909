    def _on_new_battery_detected_main_thread(self, channel_num: int, voltage: float):
        """在主线程中处理新电池检测事件"""
        try:
            # 🔧 修复：改为INFO级别，确保能看到日志
            logger.info(f"📱 在主线程中处理新电池检测: 通道{channel_num}, 电压{voltage:.3f}V")

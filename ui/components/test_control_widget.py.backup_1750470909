                # 🔧 修复：确保在手动模式下按钮状态正确
                if not self.is_testing:
                    self.start_stop_button.setText("开始测试")
                    self.start_stop_button.setObjectName("startButton")
                    self.start_stop_button.setStyleSheet("")  # 重新应用样式
                    logger.info("✅ 手动模式：按钮状态已同步为'开始测试'")

            else:

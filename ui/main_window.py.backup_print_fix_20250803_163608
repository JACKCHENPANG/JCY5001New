        try:
            logger.info("🛑 [增强版] 主窗口开始停止测试流程...")
            
            # 1. 立即设置主窗口状态
            self.is_testing = False
            
            # 2. 强制停止测试流程管理器
            if hasattr(self, 'test_flow_manager') and self.test_flow_manager:
                try:
                    self.test_flow_manager.stop_test()
